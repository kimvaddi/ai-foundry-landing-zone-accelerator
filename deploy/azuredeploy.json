{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "klz-thin-wrapper",
      "version": "1.0",
      "purpose": "Thin wrapper that forwards parameters to azuredeploy-full.json via ARM templateLink. Keeps the Portal deeplink fetch under the practical ~1MB size limit. See deploy/README.md."
    }
  },
  "parameters": {
    "workload": {
      "type": "string",
      "defaultValue": "klzfin",
      "minLength": 3,
      "maxLength": 8,
      "metadata": {
        "description": "Workload short name, used in naming. Lower-case, 3-8 chars."
      }
    },
    "env": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "test",
        "prod",
        "smoke",
        "poc",
        "sandbox"
      ],
      "metadata": {
        "description": "Environment label (dev|test|prod)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus2",
      "metadata": {
        "description": "Primary location for all resources."
      }
    },
    "searchLocation": {
      "type": "string",
      "defaultValue": "[parameters('location')]",
      "metadata": {
        "description": "Override location for AI Search (capacity in eastus2 is constrained; westus2 often has headroom)."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "workload": "[parameters('workload')]",
        "env": "[parameters('env')]",
        "owner": "platform-team",
        "costCenter": "AI-Platform",
        "managedBy": "klz-accelerator-finops"
      },
      "metadata": {
        "description": "Tags applied to every resource."
      }
    },
    "networkMode": {
      "type": "string",
      "defaultValue": "hub-connected",
      "allowedValues": [
        "standalone",
        "hub-connected"
      ],
      "metadata": {
        "description": "Networking mode. standalone = no FW, no hub (create our own DNS). hub-connected = peer to BYO hub (reference existing DNS). standalone-with-firewall is a Stage B follow-up."
      }
    },
    "components": {
      "type": "object",
      "defaultValue": {
        "bastion": {
          "deploy": false,
          "sku": "Standard"
        },
        "jumpvm": {
          "deploy": false,
          "sku": "Standard_B2s"
        },
        "buildvm": {
          "deploy": false,
          "sku": "Standard_B2s"
        },
        "appGateway": {
          "deploy": false,
          "wafEnabled": true,
          "sku": "WAF_v2"
        },
        "containerAppsEnv": {
          "deploy": false
        },
        "apim": {
          "deploy": true,
          "sku": "StandardV2",
          "networkMode": "none"
        },
        "standaloneSearch": {
          "deploy": true,
          "sku": "basic"
        },
        "notifications": {
          "deploy": false
        },
        "otelCollector": {
          "deploy": false
        }
      },
      "metadata": {
        "description": "Component toggles. Each gates its subnet creation; compute deploy follows in Stage B."
      }
    },
    "vnetAddressSpace": {
      "type": "string",
      "defaultValue": "10.50.0.0/20",
      "metadata": {
        "description": "VNet address space CIDR. Default /20 fits all 9 subnets with growth room."
      }
    },
    "hubVnetResourceId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Hub VNet resource ID — REQUIRED when networkMode=hub-connected. Format: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Network/virtualNetworks/<name>"
      }
    },
    "hubFirewallPrivateIp": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Hub firewall private IP (next-hop for forced-tunnel UDR). When empty, no UDR is created."
      }
    },
    "enableForcedTunneling": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable forced tunneling (0/0 → hub FW). Only honored when hub-connected AND hubFirewallPrivateIp is set. Set false to bring up hub-connected mode without forced tunneling (initial bring-up)."
      }
    },
    "createReverseHubPeer": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Also create the reverse hub→spoke peer. Requires write perms on hub RG. Only works for same-subscription hubs in this revision."
      }
    },
    "existingPrivateDnsZones": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "When networkMode=hub-connected, map of zoneFriendlyName→resourceId for existing private DNS zones living in the hub. See modules/networking/private-dns.bicep zoneCatalog for friendly keys."
      }
    },
    "enforceApimChokepoint": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When true, APIM AI Gateway becomes the single chokepoint for all Foundry / Search / KV data-plane traffic. Flips Foundry+Search publicNetworkAccess to Disabled, enables NSG enforcement on the PrivateEndpointSubnet, and allows only APIMSubnet (and explicitly-opted exceptions) to reach the PEs. Requires apim.deploy=true AND apim.networkMode in {external,internal}. Defaults to false so smoke / POC dry-runs work without VNet line-of-sight."
      }
    },
    "allowCaeBypass": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When chokepoint is on, also allow ContainerAppEnvironmentSubnet → PE inbound (lets CAE-hosted agent runtimes call Foundry directly, bypassing APIM). Off by default — keep APIM as the only path."
      }
    },
    "allowAgentSubnetBypass": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "When chokepoint is on AND Foundry agent injection is enabled, allow AIFoundrySubnet → PE inbound. Required for the Standard Agent Service to reach Foundry/Search PEs. On by default; safe to leave on even without agent injection (rule has no effect when subnet is empty)."
      }
    },
    "modelDeployments": {
      "type": "array",
      "defaultValue": [
        {
          "name": "gpt-4o-mini",
          "modelName": "gpt-4o-mini",
          "modelVersion": "2024-07-18",
          "skuName": "GlobalStandard",
          "capacity": "10"
        }
      ],
      "metadata": {
        "description": "Models to deploy on the Foundry account. Accepts either the FLAT shape from the Deploy-to-Azure wizard ({ name, modelName, modelVersion, skuName, capacity }) OR the legacy NESTED shape ({ name, model:{format,name,version}, sku:{name,capacity} }) — the wrapper auto-projects per row before forwarding to azuredeploy-full.json."
      }
    },
    "foundryProjects": {
      "type": "array",
      "defaultValue": [
        {
          "name": "default",
          "displayName": "Default project",
          "description": "Created by klz-accelerator-finops"
        }
      ],
      "metadata": {
        "description": "Foundry projects to create as child resources."
      }
    },
    "foundryByorConnections": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Stage B P2: Per-project BYOR connections (flat list). Each entry: { projectName, name, category, target, authType?=AAD, metadata?, isSharedToAll?=true }. Categories: CognitiveSearch | AzureBlob | AzureKeyVault | CosmosDb | Custom."
      }
    },
    "enableFoundryAgentInjection": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Stage B P2: When true, register the AIFoundrySubnet on the Foundry account as the Standard Agent Service network injection point. Independent of components.containerAppsEnv.deploy — Foundry creates its own managed CAE inside the subnet for agents."
      }
    },
    "createFoundryCapabilityHost": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Stage B P2: When true, also create an account-level capability host (kind=Agents). Required for the Standard Agent Service to host agents. Implies enableFoundryAgentInjection should also be true."
      }
    },
    "autoWireSearchConnection": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Stage B P3: When true AND components.standaloneSearch.deploy=true AND a BYOR connection of category=CognitiveSearch has an empty target, auto-fill the target to the standalone Search service endpoint. Saves operator from copy-pasting the search endpoint."
      }
    },
    "deployNotifications": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Deploy the Phase B.4 Logic App notification stub. Ships in state=Disabled regardless."
      }
    },
    "enableNotificationsLogicApp": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When deployNotifications=true, flip the Logic App workflow state to Enabled."
      }
    },
    "teamsWebhookUrl": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Incoming Webhook URL for a Teams channel. SecureString — never written to logs."
      }
    },
    "notificationEmails": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional comma-separated fallback email list for the notifications workflow."
      }
    },
    "otelSecondaryEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional secondary OTLP endpoint (gRPC) for the OTel collector."
      }
    },
    "jumpvmAdminPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Windows admin password for the jumpbox VM. REQUIRED when components.jumpvm.deploy=true. Pass via Key Vault getSecret()."
      }
    },
    "buildvmSshPublicKey": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "SSH public key (OpenSSH single-line format) for the build-agent VM. REQUIRED when components.buildvm.deploy=true."
      }
    },
    "containerAppsEnvInternal": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Internal-only Container Apps Environment. Recommended for hub-connected mode so ingress stays inside the VNet."
      }
    },
    "apimPublisherLocalPart": {
      "type": "string",
      "defaultValue": "platform",
      "metadata": {
        "description": "APIM publisher contact local-part (left of @)."
      }
    },
    "apimPublisherDomain": {
      "type": "string",
      "defaultValue": "klzfin.com",
      "metadata": {
        "description": "APIM publisher contact domain (right of @). Not validated for ownership."
      }
    },
    "apimPublisherName": {
      "type": "string",
      "defaultValue": "KLZ FinOps Platform",
      "metadata": {
        "description": "APIM publisher display name."
      }
    },
    "enableContentSafety": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable Azure AI Content Safety category scoring (Hate/Sexual/Violence/SelfHarm) on the APIM AI API. Adds llm-content-safety policy element."
      }
    },
    "enablePromptShields": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable Prompt Shields jailbreak detection on the APIM AI API. Combined with enableContentSafety into the same llm-content-safety element."
      }
    },
    "safetyThreshold": {
      "type": "int",
      "defaultValue": 4,
      "allowedValues": [
        0,
        2,
        4,
        6
      ],
      "metadata": {
        "description": "Content Safety severity threshold (FourSeverityLevels: 0/2/4/6). 4 = block medium+ severity."
      }
    },
    "enableSemanticCache": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable APIM semantic cache. Provisions Redis Enterprise (RediSearch) + APIM external cache + embeddings backend."
      }
    },
    "embeddingsDeploymentName": {
      "type": "string",
      "defaultValue": "text-embedding-3-large",
      "metadata": {
        "description": "Embedding deployment name used by the semantic cache lookup policy. Must be deployed on the Foundry account."
      }
    },
    "apimProductTokensPerMinute": {
      "type": "int",
      "defaultValue": 50000,
      "metadata": {
        "description": "Per-product TPM cap for the APIM `foundry-default` product. Templated into product-token-limit.xml."
      }
    },
    "enablePostDeployRbac": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Master switch for post-deploy RBAC. When false, no role assignments are emitted regardless of the object IDs below."
      }
    },
    "foundryAdminGroupObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Entra group object ID -> Foundry Owner on the Foundry account. Leave empty to skip."
      }
    },
    "foundryLeadGroupObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Entra group object ID -> Foundry Project Manager on the Foundry account. Leave empty to skip."
      }
    },
    "foundryDeveloperGroupObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Entra group object ID -> Foundry User on the Foundry account. Leave empty to skip."
      }
    },
    "platformReaderGroupObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Entra group object ID -> Reader on the Foundry account and platform RG. Leave empty to skip."
      }
    },
    "deploymentSpnObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Service principal object ID -> Contributor on the platform RG (CI/CD). Leave empty to skip."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "klz-foundry-landing-zone",
      "location": "[parameters('location')]",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "https://raw.githubusercontent.com/kimvaddi/ai-foundry-landing-zone-accelerator/main/deploy/azuredeploy-full.json",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "allowAgentSubnetBypass": {
            "value": "[parameters('allowAgentSubnetBypass')]"
          },
          "allowCaeBypass": {
            "value": "[parameters('allowCaeBypass')]"
          },
          "apimProductTokensPerMinute": {
            "value": "[parameters('apimProductTokensPerMinute')]"
          },
          "apimPublisherDomain": {
            "value": "[parameters('apimPublisherDomain')]"
          },
          "apimPublisherLocalPart": {
            "value": "[parameters('apimPublisherLocalPart')]"
          },
          "apimPublisherName": {
            "value": "[parameters('apimPublisherName')]"
          },
          "autoWireSearchConnection": {
            "value": "[parameters('autoWireSearchConnection')]"
          },
          "buildvmSshPublicKey": {
            "value": "[parameters('buildvmSshPublicKey')]"
          },
          "components": {
            "value": "[parameters('components')]"
          },
          "containerAppsEnvInternal": {
            "value": "[parameters('containerAppsEnvInternal')]"
          },
          "createFoundryCapabilityHost": {
            "value": "[parameters('createFoundryCapabilityHost')]"
          },
          "createReverseHubPeer": {
            "value": "[parameters('createReverseHubPeer')]"
          },
          "deployNotifications": {
            "value": "[parameters('deployNotifications')]"
          },
          "deploymentSpnObjectId": {
            "value": "[parameters('deploymentSpnObjectId')]"
          },
          "embeddingsDeploymentName": {
            "value": "[parameters('embeddingsDeploymentName')]"
          },
          "enableContentSafety": {
            "value": "[parameters('enableContentSafety')]"
          },
          "enableForcedTunneling": {
            "value": "[parameters('enableForcedTunneling')]"
          },
          "enableFoundryAgentInjection": {
            "value": "[parameters('enableFoundryAgentInjection')]"
          },
          "enableNotificationsLogicApp": {
            "value": "[parameters('enableNotificationsLogicApp')]"
          },
          "enablePromptShields": {
            "value": "[parameters('enablePromptShields')]"
          },
          "enablePostDeployRbac": {
            "value": "[parameters('enablePostDeployRbac')]"
          },
          "enableSemanticCache": {
            "value": "[parameters('enableSemanticCache')]"
          },
          "enforceApimChokepoint": {
            "value": "[parameters('enforceApimChokepoint')]"
          },
          "env": {
            "value": "[parameters('env')]"
          },
          "existingPrivateDnsZones": {
            "value": "[parameters('existingPrivateDnsZones')]"
          },
          "foundryAdminGroupObjectId": {
            "value": "[parameters('foundryAdminGroupObjectId')]"
          },
          "foundryByorConnections": {
            "value": "[parameters('foundryByorConnections')]"
          },
          "foundryDeveloperGroupObjectId": {
            "value": "[parameters('foundryDeveloperGroupObjectId')]"
          },
          "foundryLeadGroupObjectId": {
            "value": "[parameters('foundryLeadGroupObjectId')]"
          },
          "foundryProjects": {
            "value": "[parameters('foundryProjects')]"
          },
          "hubFirewallPrivateIp": {
            "value": "[parameters('hubFirewallPrivateIp')]"
          },
          "hubVnetResourceId": {
            "value": "[parameters('hubVnetResourceId')]"
          },
          "jumpvmAdminPassword": {
            "value": "[parameters('jumpvmAdminPassword')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "modelDeployments": {
            "value": "[parameters('modelDeployments')]"
          },
          "networkMode": {
            "value": "[parameters('networkMode')]"
          },
          "notificationEmails": {
            "value": "[parameters('notificationEmails')]"
          },
          "otelSecondaryEndpoint": {
            "value": "[parameters('otelSecondaryEndpoint')]"
          },
          "platformReaderGroupObjectId": {
            "value": "[parameters('platformReaderGroupObjectId')]"
          },
          "safetyThreshold": {
            "value": "[parameters('safetyThreshold')]"
          },
          "searchLocation": {
            "value": "[parameters('searchLocation')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          },
          "teamsWebhookUrl": {
            "value": "[parameters('teamsWebhookUrl')]"
          },
          "vnetAddressSpace": {
            "value": "[parameters('vnetAddressSpace')]"
          },
          "workload": {
            "value": "[parameters('workload')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "_info_chokepointAgentBypass": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs._info_chokepointAgentBypass.value]"
    },
    "_validation_chokepointApim": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs._validation_chokepointApim.value]"
    },
    "_validation_chokepointSearchRegion": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs._validation_chokepointSearchRegion.value]"
    },
    "_validation_forcedTunnel": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs._validation_forcedTunnel.value]"
    },
    "_validation_hubVnet": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs._validation_hubVnet.value]"
    },
    "agentAuditDcrId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.agentAuditDcrId.value]"
    },
    "agentAuditDcrImmutableId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.agentAuditDcrImmutableId.value]"
    },
    "agentAuditStream": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.agentAuditStream.value]"
    },
    "apimGatewayUrl": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.apimGatewayUrl.value]"
    },
    "apimResourceId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.apimResourceId.value]"
    },
    "appInsightsId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.appInsightsId.value]"
    },
    "dceEndpoint": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.dceEndpoint.value]"
    },
    "enabledSubnets": {
      "type": "array",
      "value": "[reference('klz-foundry-landing-zone').outputs.enabledSubnets.value]"
    },
    "forcedTunnelingDeployed": {
      "type": "bool",
      "value": "[reference('klz-foundry-landing-zone').outputs.forcedTunnelingDeployed.value]"
    },
    "foundryAccountId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.foundryAccountId.value]"
    },
    "foundryEndpoint": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.foundryEndpoint.value]"
    },
    "hubPeerDeployed": {
      "type": "bool",
      "value": "[reference('klz-foundry-landing-zone').outputs.hubPeerDeployed.value]"
    },
    "keyVaultId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.keyVaultId.value]"
    },
    "networkMode": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.networkMode.value]"
    },
    "notificationWorkflowId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.notificationWorkflowId.value]"
    },
    "notificationWorkflowState": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.notificationWorkflowState.value]"
    },
    "otelCollectorEnvId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.otelCollectorEnvId.value]"
    },
    "pricingDcrImmutableId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.pricingDcrImmutableId.value]"
    },
    "privateDnsZoneIds": {
      "type": "object",
      "value": "[reference('klz-foundry-landing-zone').outputs.privateDnsZoneIds.value]"
    },
    "quotaDcrImmutableId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.quotaDcrImmutableId.value]"
    },
    "searchServiceId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.searchServiceId.value]"
    },
    "stageVersion": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.stageVersion.value]"
    },
    "vnetId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.vnetId.value]"
    },
    "vnetName": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.vnetName.value]"
    },
    "workspaceCustomerId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.workspaceCustomerId.value]"
    },
    "workspaceId": {
      "type": "string",
      "value": "[reference('klz-foundry-landing-zone').outputs.workspaceId.value]"
    },
    "_wrapperInfo": {
      "type": "string",
      "value": "Deployed via thin wrapper -> azuredeploy-full.json. For CLI redeploy use scripts/deploy.ps1."
    }
  }
}