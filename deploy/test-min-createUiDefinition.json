{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "basics": [
      {
        "name": "workload",
        "type": "Microsoft.Common.TextBox",
        "label": "Workload short name",
        "defaultValue": "klztest",
        "toolTip": "Used in the test resource group name.",
        "constraints": {
          "required": true,
          "regex": "^[a-z][a-z0-9]{2,7}$",
          "validationMessage": "Lower-case letters/digits, 3-8 chars."
        }
      }
    ],
    "steps": [],
    "outputs": {
      "workload": "[basics('workload')]",
      "location": "[location()]"
    }
  }
}
