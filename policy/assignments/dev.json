{
  "$schema": "https://schema.management.azure.com/schemas/2019-09-01/policyAssignment.json#",
  "name": "klz-foundry-baseline-dev",
  "properties": {
    "displayName": "Foundry Enterprise Baseline — DEV (audit)",
    "policyDefinitionId": "klz-foundry-baseline",
    "enforcementMode": "Default",
    "parameters": {
      "effect":               { "value": "Audit" },
      "approvedLocations":    { "value": [ "eastus", "eastus2", "westus2", "westus3" ] },
      "requiredTags":         { "value": [ "workload", "env", "owner", "costCenter" ] }
    },
    "metadata": {
      "assignedBy": "klz-accelerator-finops",
      "notes": "DEV assignment runs everything in Audit mode so the dashboard lights up without blocking experimentation. Switch effect to 'Deny' when promoting to PROD."
    }
  }
}
