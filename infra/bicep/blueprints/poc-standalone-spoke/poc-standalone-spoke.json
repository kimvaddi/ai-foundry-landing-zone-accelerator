      "value": [
        {
          "name": "gpt-4o-mini",
          "model": {
            "format": "OpenAI",
            "name": "gpt-4o-mini",
            "version": "2024-07-18"
          },
          "sku": {
            "name": "GlobalStandard",
            "capacity": 10
          }
        }
      ]
